# ===== Chave do Gemini (Google AI Studio) =====
# Necessária só para os agentes de IA. A persistência do plano funciona sem ela.
GEMINI_API_KEY=

# ===== Servidor =====
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
LOG_LEVEL=info

# ===== MySQL =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=planejamento
DB_PASSWORD=
DB_NAME=planejamento_estrategico
DB_CONNECTION_LIMIT=10

# ===== Listagem admin de leads (opcional) =====
# Se definido, GET /leads passa a aceitar o header x-admin-token com este valor.
LEADS_ADMIN_TOKEN=

# ===== Criptografia de PII (obrigatório em produção) =====
# 32 bytes em hex. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AES-256-GCM cifra: person_name, company_name, email, phone (e dados numéricos sensíveis).
ENCRYPTION_KEY=
# HMAC determinístico — permite dedup de email/IP sem expor o valor original.
HMAC_KEY=

# Rotação de chaves (opcional): incremente quando trocar ENCRYPTION_KEY.
# Mantenha a chave antiga em ENCRYPTION_KEY_V1, ENCRYPTION_KEY_V2... pra ler
# dados antigos enquanto o sistema regrava com a nova versão.
ENCRYPTION_KEY_VERSION=1

# ===== Proxy reverso (Cloudflare/Nginx) =====
# Se o backend está atrás de proxy, defina TRUST_PROXY=true pra ler IP real
# do header X-Forwarded-For. Caso contrário, o limite por IP travaria no IP do proxy.
TRUST_PROXY=false

# ===== NODE_ENV =====
# Em "production", o servidor RECUSA subir sem ENCRYPTION_KEY/HMAC_KEY
# e o cookie de sessão vai com SameSite=None; Secure (exige HTTPS).
NODE_ENV=development
